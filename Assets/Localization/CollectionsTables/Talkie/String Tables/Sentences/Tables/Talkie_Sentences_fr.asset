  m_TableData:
  - m_Id: 1673858785280
    m_Localized: "H\xE9, bienvenue sur mon bateau."
    m_Metadata:
      m_Items: []
  - m_Id: 64396571760009216
    m_Localized: "Nous sommes encore assez loin de l'ile. \nPourquoi ne prendrais
      tu pas les jumelles sur le pont ?"
    m_Metadata:
      m_Items: []
  - m_Id: 64396047727861760
    m_Localized: "La mer s'agite, il risque d'y avoir une temp\xEAte bient\xF4t."
    m_Metadata:
      m_Items: []
  - m_Id: 64402566867460096
    m_Localized: "Parfait, l'isle devrait se trouver droit devant. \nUtilise les
      jumelles pour regarder un peu."
    m_Metadata:
      m_Items: []
  - m_Id: 64456985940205568
    m_Localized: "Tu vois la bou\xE9e \xE0 droite du bateau ? \nLorsqu'elle est verte
      c'est qu'elle fonctionne parfaitement, \nsi elle est rouge c'est qu'il y'a
      un probl\xE8me \xE0 signaler."
    m_Metadata:
      m_Items: []
  - m_Id: 64778906061905920
    m_Localized: "Nous sommes arriv\xE9s, je te laisse ici pour retourner \xE0 la
      c\xF4te. \nR\xE9cup\xE8re la lampe sur le ponton et va vers le phare au nord
      de l'Isle."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
