  m_SharedData: {fileID: 11400000, guid: b38a2678b34936347914061fb5e25130, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 1673858785280
    m_Localized: 1-2, 1-2, tu m'entends ?
    m_Metadata:
      m_Items: []
  - m_Id: 6363065491456
    m_Localized: Prends la corde et amarre le bateau.
    m_Metadata:
      m_Items: []
  - m_Id: 1010131441688576
    m_Localized: Essaie d'enter dans le phare.
    m_Metadata:
      m_Items: []
  - m_Id: 1010393535356928
    m_Localized: "Forc\xE9ment, c'est ferm\xE9.\n"
    m_Metadata:
      m_Items: []
  - m_Id: 1010678181797888
    m_Localized: Je suppose qu'il n'y a pas de courant.
    m_Metadata:
      m_Items: []
  - m_Id: 1010971917295616
    m_Localized: "Essaie d'aller voir le tableau \xE9lectrique."
    m_Metadata:
      m_Items: []
  - m_Id: 1011165459259392
    m_Localized: "Il devrait y avoir une cl\xE9 pas loin de la porte."
    m_Metadata:
      m_Items: []
  - m_Id: 1011325102858240
    m_Localized: Tu ne peux pas l'ouvrir ? ... Des coquillages ?
    m_Metadata:
      m_Items: []
  - m_Id: 1011714107777024
    m_Localized: Il devrait y avoir quelque chose pour nettoyer cela.
    m_Metadata:
      m_Items: []
  - m_Id: 1011922099118080
    m_Localized: "H\xE9, regarde la notice \xE0 droite."
    m_Metadata:
      m_Items: []
  - m_Id: 1012178840854528
    m_Localized: "C'est allum\xE9 ? Maintenant monte les escaliers."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
