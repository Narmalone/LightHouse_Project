  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Talkie_Sentences_fr
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: fr
  m_SharedData: {fileID: 11400000, guid: b38a2678b34936347914061fb5e25130, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 1673858785280
    m_Localized: "Debout, bouge-toi, paresseux ! La temp\xEAte approche, on vient
      de percuter une balise !"
    m_Metadata:
      m_Items: []
  - m_Id: 64396571760009216
    m_Localized: "... Zut ! ... Vite, d\xE8s que vous les avez, regardez vers le
      phare !"
    m_Metadata:
      m_Items: []
  - m_Id: 64396047727861760
    m_Localized: "Prends ces fichues jumelles et d\xE9p\xEAche-toi ! \nJ'ai besoin
      de trouver le bon cap, je ne vois rien dans cette pluie."
    m_Metadata:
      m_Items: []
  - m_Id: 88770066673442816
    m_Localized: "Euh... Il y a quelque chose qui cloche avec cette lumi\xE8re. \nRegardez
      \xE0 gauche, vous voyez un rocher \npointu qui d\xE9passe de l'eau ?"
    m_Metadata:
      m_Items: []
  - m_Id: 88780824161427456
    m_Localized: "Tr\xE8s bien, je m'en occuperai ! Maintenant, dis-moi, est-ce que
      ce choc a endommag\xE9 cette fichue bou\xE9e ou pas ?"
    m_Metadata:
      m_Items: []
  - m_Id: 89111561792266240
    m_Localized: "Feu rouge ? Ah, bon sang... Il est cens\xE9 \xEAtre vert quand
      il fonctionne correctement... \nIl doit \xEAtre cass\xE9. Je v\xE9rifierai
      plus tard. Et mon bateau, il est toujours en un seul morceau, hein ?"
    m_Metadata:
      m_Items: []
  - m_Id: 89136601497739264
    m_Localized: "... Quoi ? Un tuyau tordu ? Bon sang... \nJe ne peux pas l\xE2cher
      la barre maintenant ! Tu vas devoir t'en occuper toi-m\xEAme ! \nPrends un
      marteau et donne quelques bons coups sur ce fichu truc jusqu'\xE0 ce qu'il
      \nse redresse !"
    m_Metadata:
      m_Items: []
  - m_Id: 89136945799766016
    m_Localized: "Et voil\xE0, nous allons y arriver apr\xE8s tout !"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
