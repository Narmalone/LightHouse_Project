  m_SharedData: {fileID: 11400000, guid: b38a2678b34936347914061fb5e25130, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 1673858785280
    m_Localized: "Up ye get, haul yer lazy hide up! Storm\u2019s comin\u2019, we
      just rammed a bloody buoy!"
    m_Metadata:
      m_Items: []
  - m_Id: 64396571760009216
    m_Localized: "We're still quite a distance from the island. \nWhy don't you take
      the binoculars up on deck?"
    m_Metadata:
      m_Items: []
  - m_Id: 64396047727861760
    m_Localized: The sea is getting rough, there may be a storm coming soon.
    m_Metadata:
      m_Items: []
  - m_Id: 64402566867460096
    m_Localized: "Perfect, the island should be right ahead. \nUse the binoculars
      to take a look."
    m_Metadata:
      m_Items: []
  - m_Id: 64456985940205568
    m_Localized: 'Can you see the buoy to the right of the boat ?

      When it
      is green, it means it is working perfectly,

      if it is red, it means there
      is a problem to report.'
    m_Metadata:
      m_Items: []
  - m_Id: 64778906061905920
    m_Localized: "We've arrived. I'll leave you here and head back to the coast.
      \nGrab the lamp from the dock and head to the \nlighthouse north of the island."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
