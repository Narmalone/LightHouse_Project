    - target: {fileID: 4405857617976185514, guid: bc9935ad3be9c914f9180208af63c488,
        type: 3}
      propertyPath: m_text
      value: "<line-height=110%><align=left>\r\n<size=150%><b>Nightwatch Report \u2013
        [Date]</b></size>\r\n<align=right><i>From : Harbor Master\u2019s Office</i></align>\r\n<align=left>\r\n\r\n<b>Dear
        [Keeper\u2019s Name],</b>\r\n\r\nPlease find below the summary of your night
        watch:\r\n\r\n<b>Boats:</b>\r\n\u2022 Correct reports: [X]\r\n\u2022 Errors:
        [X]\r\n\r\n<b>Buoys:</b>\r\n\u2022 Correct nominal buoys: [X]\r\n\u2022 Correct
        defective buoys: [X]\r\n\u2022 Errors: [X]\r\n\r\n<b>Total earnings: <color=#00C853>[$$]</color></b>\r\n\r\n<b>Captain\u2019s
        Note:</b>\r\n<i>Bravo, Keeper! Excellent work tonight: your vigilance keeps
        the waters safe.</i>\r\n\u2014or\u2014\r\n<i>Your performance did not meet
        expectations tonight. Please review your reports carefully: accuracy is essential
        for the safety of our seas.</i>\r\n\r\nRespectfully,\r\nHarbor Master\u2019s
        Office\r\n"
      objectReference: {fileID: 0}
