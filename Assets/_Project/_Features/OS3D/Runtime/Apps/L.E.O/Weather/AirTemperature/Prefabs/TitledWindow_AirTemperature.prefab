  _tips:
  - Title: Biting Cold
    Description: Hypothermia risk. Wear multiple layers, gloves, and a hat.
    TipMinTemperature: -20
    TipMaxTemperature: 0
  - Title: Chilly
    Description: Bring a windproof jacket. Light activity helps you stay warm.
    TipMinTemperature: 0
    TipMaxTemperature: 6
  - Title: Mild
    Description: Comfortable conditions. Light layers; keep an eye on the wind.
    TipMinTemperature: 6
    TipMaxTemperature: 14
  - Title: Temperate
    Description: Great working weather. Stay hydrated and use sun protection.
    TipMinTemperature: 14
    TipMaxTemperature: 25
  - Title: Hot
    Description: Heat exhaustion risk. Use a cap, sunscreen, and take shade breaks.
    TipMinTemperature: 22
    TipMaxTemperature: 45
