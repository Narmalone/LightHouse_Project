  _thermometerMaterial: {fileID: 2100000, guid: b3927bc6eb68e224f86ce78372cc014c,
    type: 2}
  _fillAmountProperty: _FillAmount
  _tipTitleText: {fileID: 1440905233407725539}
  _tipDescriptionText: {fileID: 6499470833810004333}
  _minTemperature: -10
  _maxTemperature: 30
  _tips:
  - Title: Icy Water
    Description: "Dangerous immersion (<10\xB0C). Full wetsuit or avoid entering"
    TipMinTemperature: -20
    TipMaxTemperature: 2
  - Title: Cold
    Description: Rapid hypothermia possible. Thick wetsuit recommended.
    TipMinTemperature: 2
    TipMaxTemperature: 15
  - Title: Cool
    Description: Tolerable for short periods. Light thermal protection advised.
    TipMinTemperature: 15
    TipMaxTemperature: 20
  - Title: Comfortable
    Description: Good endurance at the surface. Watch wind and currents.
    TipMinTemperature: 20
    TipMaxTemperature: 26
  - Title: Very Warm
    Description: Faster fatigue and dehydration. Hydrate frequently.
    TipMinTemperature: 26
    TipMaxTemperature: 36
