  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Talkie_Sentences_en
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: b38a2678b34936347914061fb5e25130, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 1673858785280
    m_Localized: "Up ye get, haul yer lazy hide up! Storm\u2019s comin\u2019, we
      just rammed a bloody buoy!"
    m_Metadata:
      m_Items: []
  - m_Id: 64396571760009216
    m_Localized: "...Blast! ... Quick now, soon as ye got \u2019em, look toward the
      lighthouse!"
    m_Metadata:
      m_Items: []
  - m_Id: 64396047727861760
    m_Localized: "Take those damn binoculars and get a move on ! \nI need the right
      course, can\u2019t see a bloody thing in this rain."
    m_Metadata:
      m_Items: []
  - m_Id: 88770066673442816
    m_Localized: "Er... Something ain\u2019t right with that light. \nLook t\u2019the
      left, see if ye can spot a sharp rock stickin\u2019 \noutta the water, eh ?"
    m_Metadata:
      m_Items: []
  - m_Id: 88780824161427456
    m_Localized: "Alright then, I\u2019ll manage! Now tell me, did that knock mess
      up the damn buoy or not?"
    m_Metadata:
      m_Items: []
  - m_Id: 89111561792266240
    m_Localized: "Red light? Ah, hell\u2026 it\u2019s s\u2019pposed to be green when
      it\u2019s workin\u2019 right\u2026 Must\u2019ve busted it. I\u2019ll check
      it later. \nAnd my boat, she\u2019s still in one piece, eh?"
    m_Metadata:
      m_Items: []
  - m_Id: 89136601497739264
    m_Localized: "...What? A bent pipe? Bah, hell\u2019s teeth\u2026  Can\u2019t
      let go o\u2019 the helm right now! \nYou\u2019ll have to sort it out yourself!
      Grab a hammer and give the damn thing \na few good whacks till it straightens
      out!"
    m_Metadata:
      m_Items: []
  - m_Id: 89136945799766016
    m_Localized: "There we go, we\u2019ll make it after all!"
    m_Metadata:
      m_Items: []
  - m_Id: 89411141595439104
    m_Localized: "Now grab yer bag and get ready to jump onto the pier. And before
      ye ask, nah, I ain\u2019t comin\u2019 with ye. \nNever set foot on that cursed
      rock, and I sure as hell ain\u2019t startin\u2019 tonight."
    m_Metadata:
      m_Items: []
  - m_Id: 89413601676369920
    m_Localized: "Oh and b\u2019fore you go\u2026 Put the hammer back where ye found
      it, \nmight need it in a bit."
    m_Metadata:
      m_Items: []
  - m_Id: 89413913048915968
    m_Localized: "Alright then, first thing, go take care o\u2019 the lighthouse
      lens, that\u2019s the priority. \nAnd don\u2019t fret, I ain\u2019t leavin\u2019
      ye alone just yet. I\u2019ll keep talkin\u2019 to ye through the pager. \nNow
      move yer damn feet!"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
